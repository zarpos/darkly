# -*- mode: ruby -*-
# vi: set ft=ruby :

# ─────────────────────────────────────────────────────────────
#  Darkly – BornToSec Web Security Challenge
#
#  Requisitos:
#    - VirtualBox instalado
#    - Vagrant instalado
#    - Darkly_*.iso en esta misma carpeta (setup/)
#
#  Uso:
#    vagrant up      → crea y arranca la VM
#    vagrant halt    → apaga la VM
#    vagrant destroy → elimina la VM
# ─────────────────────────────────────────────────────────────

VM_NAME  = "Darkly_BornToSec"
HOST_NET = "vboxnet0"

# ── Detectar ISO ─────────────────────────────────────────────
iso_path = Dir.glob(File.join(__dir__, "*.iso")).first
abort "\e[31m[ERROR]\e[0m No se encontró ningún .iso en #{__dir__}" unless iso_path
puts "\e[32m[info]\e[0m ISO detectada: #{iso_path}"

# ── Interceptar vagrant up/halt/destroy con VBoxManage directo
# Esto evita que Vagrant intente conectar por SSH a la VM
cmd = ARGV.first

if cmd == "up"
  # Crear interfaz host-only si no existe
  unless `VBoxManage list hostonlyifs 2>/dev/null`.include?(HOST_NET)
    puts "[setup] Creando interfaz host-only..."
    system("VBoxManage", "hostonlyif", "create")
  end

  # Si ya está corriendo, no hacer nada
  if `VBoxManage list runningvms 2>/dev/null`.include?("\"#{VM_NAME}\"")
    puts "\e[33m[info]\e[0m La VM ya está corriendo."
  else
    # Crear VM solo si no existe ya
    unless `VBoxManage list vms 2>/dev/null`.include?("\"#{VM_NAME}\"")
      puts "[setup] Creando VM #{VM_NAME}..."

      system("VBoxManage", "createvm",
             "--name", VM_NAME, "--ostype", "Ubuntu_64", "--register")

      system("VBoxManage", "modifyvm", VM_NAME,
             "--memory",         "2048",
             "--cpus",           "2",
             "--boot1",          "dvd",
             "--boot2",          "none",
             "--boot3",          "none",
             "--boot4",          "none",
             "--nic1",           "nat",
             "--nic2",           "hostonly",
             "--hostonlyadapter2", HOST_NET,
             "--usb",            "off",
             "--audio",          "none",
             "--biosbootmenu",   "disabled",
             "--graphicscontroller", "vmsvga",
             "--vram",           "128",
             "--ioapic",         "off")

      system("VBoxManage", "storagectl", VM_NAME,
             "--name",       "IDE Controller",
             "--add",        "ide",
             "--controller", "PIIX4")

      system("VBoxManage", "storageattach", VM_NAME,
             "--storagectl", "IDE Controller",
             "--port",       "0",
             "--device",     "0",
             "--type",       "dvddrive",
             "--medium",     iso_path)
    end

    puts "[setup] Arrancando VM..."
    system("VBoxManage", "startvm", VM_NAME, "--type", "gui")
  end

  puts "\e[32m✔ Darkly VM arrancada!\e[0m"
  puts "  Mira la IP en la pantalla de la VM y abre el navegador en esa IP."
  exit 0
end

if cmd == "halt"
  puts "[setup] Apagando VM..."
  system("VBoxManage", "controlvm", VM_NAME, "acpipowerbutton")
  exit 0
end

if cmd == "destroy"
  puts "[setup] Eliminando VM..."
  system("VBoxManage", "controlvm", VM_NAME, "poweroff") rescue nil
  sleep 2
  system("VBoxManage", "unregistervm", VM_NAME, "--delete")
  exit 0
end

# Configuración mínima para que vagrant no falle en otros subcomandos
Vagrant.configure("2") do |config|
  config.vm.box = "hashicorp/bionic64"
end
